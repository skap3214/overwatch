{
  "name": "overwatch-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "ip": "echo \"Metro: http://$(ipconfig getifaddr en0 || ipconfig getifaddr en1):8081\"",
    "prebuild": "expo prebuild --clean",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:prod:ios": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --profile production --platform ios --latest",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@daily-co/react-native-daily-js": "0.82.0",
    "@daily-co/react-native-webrtc": "124.0.6-daily.1",
    "@expo/metro-runtime": "~55.0.10",
    "@expo/ngrok": "^4.1.3",
    "@noble/hashes": "^2.2.0",
    "@pipecat-ai/client-js": "1.7.0",
    "@pipecat-ai/react-native-daily-transport": "1.6.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "buffer": "^6.0.3",
    "croner": "^10.0.1",
    "expo": "~55.0.13",
    "expo-audio": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-constants": "^55.0.13",
    "expo-dev-client": "~55.0.30",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "^55.0.12",
    "expo-router": "^55.0.11",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "^55.0.15",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-background-timer": "^2.4.1",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-pager-view": "^8.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.13",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
