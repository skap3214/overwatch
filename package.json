{
  "name": "overwatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "overwatch": "tsx packages/cli/src/index.ts",
    "setup": "tsx packages/cli/src/index.ts setup",
    "overwatch:start": "tsx packages/cli/src/index.ts start",
    "overwatch:status": "tsx packages/cli/src/index.ts status",
    "overwatch:update": "tsx packages/cli/src/index.ts update",
    "test": "tsx --test tests/**/*.test.ts",
    "protocol:gen": "npm run protocol:gen:ts && npm run protocol:gen:py",
    "protocol:gen:ts": "node scripts/codegen-ts.mjs",
    "protocol:gen:py": "bash scripts/codegen-py.sh",
    "protocol:check": "node scripts/codegen-check.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^16.5.0",
    "hono": "^4.8.3",
    "prompts": "^2.4.2",
    "qrcode-terminal": "^0.12.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/ws": "^8.5.14",
    "json-schema-to-typescript": "15.0.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
