{
  "name": "overwatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "daemon:dev": "tsx watch packages/session-host-daemon/src/index.ts",
    "daemon:build": "tsc -p packages/session-host-daemon/tsconfig.json",
    "overwatch": "tsx packages/cli/src/index.ts",
    "setup": "tsx packages/cli/src/index.ts setup",
    "overwatch:start": "tsx packages/cli/src/index.ts start",
    "overwatch:status": "tsx packages/cli/src/index.ts status",
    "overwatch:update": "tsx packages/cli/src/index.ts update",
    "test": "tsx --test tests/cli-setup-validation.test.ts tests/cli-terminal-setup.test.ts tests/cross-runtime-token-contract.test.ts packages/session-host-daemon/tests/*.test.ts overwatch-mobile/tests/*.test.ts",
    "test:cli": "tsx --test tests/cli-setup-validation.test.ts tests/cli-terminal-setup.test.ts",
    "test:daemon": "tsx --test packages/session-host-daemon/tests/*.test.ts",
    "test:mobile": "tsx --test overwatch-mobile/tests/*.test.ts",
    "test:contract": "tsx --test tests/cross-runtime-token-contract.test.ts",
    "protocol:gen": "npm run protocol:gen:ts && npm run protocol:gen:py",
    "protocol:gen:ts": "node scripts/codegen-ts.mjs",
    "protocol:gen:py": "bash scripts/codegen-py.sh",
    "protocol:check": "node scripts/codegen-check.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/ws": "^8.5.14",
    "json-schema-to-typescript": "15.0.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
