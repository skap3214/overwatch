{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overwatch.dev/protocol/server-message.schema.json",
  "title": "ServerMessage",
  "description": "Typed envelopes for non-RTVI events flowing between the cloud orchestrator and the mobile client over the Daily WebRTC data channel. Sits alongside the RTVI standard messages (user-transcription, bot-llm-text, etc.) which are not redefined here.",
  "oneOf": [
    { "$ref": "#/$defs/UserText" },
    { "$ref": "#/$defs/HarnessEventForUI" },
    { "$ref": "#/$defs/HarnessStateSnapshot" },
    { "$ref": "#/$defs/HarnessSnapshot" },
    { "$ref": "#/$defs/MonitorSnapshot" },
    { "$ref": "#/$defs/SkillsSnapshot" },
    { "$ref": "#/$defs/MonitorActionResult" },
    { "$ref": "#/$defs/InterruptIntent" },
    { "$ref": "#/$defs/Notification" },
    { "$ref": "#/$defs/ErrorResponse" }
  ],
  "$defs": {
    "HarnessCapabilities": {
      "type": "object",
      "required": [
        "hasNativeCron",
        "hasNativeSkills",
        "hasNativeMemory",
        "hasSessionContinuity",
        "emitsReasoning",
        "voiceConvention"
      ],
      "additionalProperties": false,
      "properties": {
        "hasNativeCron": { "type": "boolean" },
        "hasNativeSkills": { "type": "boolean" },
        "hasNativeMemory": { "type": "boolean" },
        "hasSessionContinuity": { "type": "boolean" },
        "emitsReasoning": { "type": "boolean" },
        "voiceConvention": {
          "enum": ["soul-md", "instructions-prefix", "none"]
        }
      }
    },
    "AgentProviderInfo": {
      "type": "object",
      "required": [
        "id",
        "name",
        "tagline",
        "description",
        "capabilities",
        "installed"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/HarnessCapabilities" },
        "installed": { "type": "boolean" },
        "installInstruction": { "type": "string" }
      }
    },
    "MonitorActionMetadata": {
      "type": "object",
      "required": [
        "source",
        "provider_id",
        "can_create",
        "can_edit",
        "can_delete",
        "can_pause",
        "can_resume",
        "can_run_now",
        "supports_run_history"
      ],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["local", "hermes"] },
        "provider_id": { "type": "string" },
        "can_create": { "type": "boolean" },
        "can_edit": { "type": "boolean" },
        "can_delete": { "type": "boolean" },
        "can_pause": { "type": "boolean" },
        "can_resume": { "type": "boolean" },
        "can_run_now": { "type": "boolean" },
        "supports_run_history": { "type": "boolean" },
        "unsupported_reason": { "type": "string" }
      }
    },
    "ScheduledMonitor": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "scheduleLabel": { "type": "string" },
        "nextRunAt": { "type": ["string", "null"] },
        "lastFiredAt": { "type": ["string", "null"] },
        "recurring": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "state": { "type": "string" },
        "lastStatus": { "enum": ["ok", "error", null] },
        "lastError": { "type": ["string", "null"] },
        "paused": { "type": "boolean" },
        "source": { "enum": ["local", "hermes"] }
      }
    },
    "ActiveSkill": {
      "type": "object",
      "required": ["name", "description", "category", "enabled"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "enabled": { "type": "boolean" },
        "version": { "type": "string" }
      }
    },
    "UserText": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "description": "User-typed text from mobile InputBar. Handled by the orchestrator's HarnessBridgeProcessor identically to a voice transcript: in-flight check, then submit_text or submit_with_steer.",
      "properties": {
        "type": { "const": "user_text" },
        "text": { "type": "string" }
      }
    },
    "HarnessEventForUI": {
      "type": "object",
      "required": ["type", "event"],
      "additionalProperties": false,
      "description": "Wraps a HarnessEvent the orchestrator's registry routed to voice_action='ui-only'. Mobile renders as transcript pill / status row.",
      "properties": {
        "type": { "const": "harness_event" },
        "event": {
          "description": "Full HarnessEvent payload (see harness-event.schema.json).",
          "type": "object"
        }
      }
    },
    "HarnessStateSnapshot": {
      "type": "object",
      "required": ["type", "active_target", "in_flight"],
      "additionalProperties": false,
      "description": "Periodic state snapshot for the mobile UI to derive 'is the harness busy' indicators.",
      "properties": {
        "type": { "const": "harness_state" },
        "active_target": { "type": "string" },
        "in_flight": { "type": "boolean" },
        "active_correlation_id": { "type": "string" }
      }
    },
    "HarnessSnapshot": {
      "type": "object",
      "required": [
        "type",
        "active_provider_id",
        "active_target",
        "capabilities",
        "providers",
        "in_flight"
      ],
      "additionalProperties": false,
      "description": "Mobile-facing harness/provider snapshot. Superset of harness_state; harness_state remains for inference-gate compatibility.",
      "properties": {
        "type": { "const": "harness_snapshot" },
        "active_provider_id": { "type": "string" },
        "active_target": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/HarnessCapabilities" },
        "providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentProviderInfo" }
        },
        "in_flight": { "type": "boolean" },
        "active_correlation_id": { "type": "string" }
      }
    },
    "MonitorSnapshot": {
      "type": "object",
      "required": ["type", "monitors", "actions"],
      "additionalProperties": false,
      "description": "Mobile-facing monitor list plus source/action metadata for capability-aware controls.",
      "properties": {
        "type": { "const": "monitor_snapshot" },
        "monitors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScheduledMonitor" }
        },
        "actions": { "$ref": "#/$defs/MonitorActionMetadata" }
      }
    },
    "SkillsSnapshot": {
      "type": "object",
      "required": ["type", "provider_id", "skills"],
      "additionalProperties": false,
      "description": "Mobile-facing active skills snapshot for providers with native skill surfaces.",
      "properties": {
        "type": { "const": "skills_snapshot" },
        "provider_id": { "type": "string" },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/ActiveSkill" }
        }
      }
    },
    "MonitorActionResult": {
      "type": "object",
      "required": ["type", "request_id", "ok"],
      "additionalProperties": false,
      "description": "Correlated response to a mobile monitor_action / daemon manage_monitor command.",
      "properties": {
        "type": { "const": "monitor_action_result" },
        "request_id": { "type": "string" },
        "ok": { "type": "boolean" },
        "action": {
          "enum": [
            "list",
            "get",
            "create",
            "update",
            "delete",
            "pause",
            "resume",
            "run_now",
            "list_runs",
            "read_run"
          ]
        },
        "monitor": { "$ref": "#/$defs/ScheduledMonitor" },
        "monitors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScheduledMonitor" }
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "content": { "type": "string" },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "InterruptIntent": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "description": "PTT press from mobile. Hint to the orchestrator to begin the audio_stopped phase early. Not authoritative — the actual cancellation only happens once a transcript or user_text is received.",
      "properties": {
        "type": { "const": "interrupt_intent" }
      }
    },
    "Notification": {
      "type": "object",
      "required": ["type", "id", "title", "body", "kind"],
      "additionalProperties": false,
      "description": "Overwatch-internal notification surfaced to the mobile UI. Mirrors the existing notification system.",
      "properties": {
        "type": { "const": "notification" },
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "kind": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "speakable_text": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "object", "additionalProperties": true },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": ["type", "request_id", "error"],
      "additionalProperties": false,
      "description": "Correlated error response. request_id echoes the originating envelope's id so the client can match.",
      "properties": {
        "type": { "const": "error_response" },
        "request_id": { "type": "string" },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
