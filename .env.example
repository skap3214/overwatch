# Voice/harness-bridge overhaul — env var template
# Copy to .env.local and fill in real values. .env.local is gitignored.

# ─── Voice pipeline (orchestrator runtime) ──────────────────────────────────

# Cartesia — TTS (Sonic streaming)
# https://play.cartesia.ai/
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=brooke

# Deployment default TTS provider. Individual installs set their provider in
# ~/.overwatch/config.json via `overwatch setup --tts cartesia|xai`; the QR
# pairing payload passes that preference to the phone.
TTS_PROVIDER=cartesia

# xAI — TTS (streaming WebSocket)
# https://console.x.ai/
XAI_API_KEY=
XAI_TTS_VOICE=eve
XAI_TTS_LANGUAGE=en
XAI_TTS_SAMPLE_RATE=
XAI_TTS_OPTIMIZE_STREAMING_LATENCY=1

# Deepgram — STT (Nova-3 streaming)
# https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ─── Pipecat Cloud ──────────────────────────────────────────────────────────

# Public key (pk_...) used by the CF Workers relay to mint Daily room tokens
# for phones. The phone never holds this key directly.
# Dashboard → API Keys → "Public key"
PIPECAT_PUBLIC_KEY=

# ─── Observability ──────────────────────────────────────────────────────────

# OTel — pick one backend (Honeycomb / Axiom / Grafana Cloud / local Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Sentry — error tracking, both runtimes
SENTRY_DSN=

# ─── Mac daemon ─────────────────────────────────────────────────────────────

# Provided by the relay during `overwatch setup` — written to daemon config,
# not typically set in .env. Documented here for reference.
# ORCHESTRATOR_URL=
# ORCHESTRATOR_TOKEN=
